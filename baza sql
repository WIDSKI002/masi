CREATE TABLE terminy_szkolen (
    id SERIAL PRIMARY KEY,
    szkolenie_id INT NOT NULL,
    termin TIMESTAMP NOT NULL,
    FOREIGN KEY (szkolenie_id) REFERENCES szkolenia(id) ON DELETE CASCADE
);