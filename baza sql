
-- Skrypt PostgreSQL: tworzy tabele potrzebne dla aplikacji kalendarza
-- Wklej do klienta psql lub uruchom z pliku.

-- (Opcjonalnie) utwórz bazę i połącz się z nią przed uruchomieniem:
-- createdb masi_db
-- psql -d masi_db -f "baza sql"

BEGIN;

-- Tabela stawek (rates): każda zmiana ma datę obowiązywania
CREATE TABLE IF NOT EXISTS rates (
	id SERIAL PRIMARY KEY,
	effective_date DATE NOT NULL,
	whole_day NUMERIC NOT NULL,
	fuel NUMERIC NOT NULL,
	created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);
CREATE UNIQUE INDEX IF NOT EXISTS idx_rates_effective_date ON rates (effective_date);

-- Tabela zapisów kalendarza
CREATE TABLE IF NOT EXISTS calendar_entries (
	id SERIAL PRIMARY KEY,
	entry_date DATE UNIQUE NOT NULL,
	option VARCHAR(20) NOT NULL CHECK (option IN ('caly','paliwo','nie_caly')),
	not_full_hours NUMERIC,
	created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);
CREATE INDEX IF NOT EXISTS idx_calendar_entry_date ON calendar_entries (entry_date);

-- Jeśli nie ma jeszcze żadnej stawki, dodaj domyślną (250 / 50)
DO $$
BEGIN
	IF (SELECT COUNT(*) FROM rates) = 0 THEN
		INSERT INTO rates (effective_date, whole_day, fuel) VALUES ('1970-01-01', 250, 50);
	END IF;
END
$$;

-- Funkcja pomocnicza: oblicza cenę dla danego zapisu na podstawie obowiązującej stawki
CREATE OR REPLACE FUNCTION calc_price(entry_date DATE, opt VARCHAR, hours NUMERIC)
RETURNS NUMERIC AS $$
DECLARE
	r RECORD;
	price NUMERIC := 0;
BEGIN
	SELECT * INTO r FROM rates WHERE effective_date <= entry_date ORDER BY effective_date DESC LIMIT 1;
	IF r IS NULL THEN
		RAISE EXCEPTION 'No applicable rate found for %', entry_date;
	END IF;
	IF opt = 'caly' THEN
		price := r.whole_day;
	ELSIF opt = 'paliwo' THEN
		price := r.fuel;
	ELSIF opt = 'nie_caly' THEN
		-- Przyjęto dzień bazowy jako 8 godzin. Dostosuj jeśli potrzebne.
		price := r.whole_day * COALESCE(hours,0) / 8.0;
	ELSE
		RAISE EXCEPTION 'Unknown option: %', opt;
	END IF;
	RETURN price;
END;
$$ LANGUAGE plpgsql STABLE;

-- Widok łączący zapisy z wyliczoną ceną i datą obowiązującej stawki
CREATE OR REPLACE VIEW calendar_with_price AS
SELECT
	c.*,
	calc_price(c.entry_date, c.option, c.not_full_hours) AS price,
	(SELECT effective_date FROM rates WHERE effective_date <= c.entry_date ORDER BY effective_date DESC LIMIT 1) AS rate_effective_date
FROM calendar_entries c;

COMMIT;

